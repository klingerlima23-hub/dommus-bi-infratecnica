# Template de variaveis de ambiente. Copie para .env.local e preencha
# com os valores REAIS. NUNCA preencha credenciais reais aqui ou commit
# este arquivo com dados sensiveis -- .env.example deve ser publico.

# DW Destino (MySQL onde o dashboard le os dados)
DB_HOST=host.do.dw
DB_PORT=3310
DB_USER=USUARIO_DESTINO
DB_PASSWORD=SENHA_DESTINO
DB_DATABASE=dw_infratecnica

# JWT secret pra assinar tokens de sessao
# Gere com: openssl rand -hex 32   (ou no PowerShell: -join ((1..64) | %{ '{0:x}' -f (Get-Random -Maximum 16) }))
JWT_SECRET=GERAR_NOVO_64_HEX_CHARS

# Optional: link de suporte WhatsApp (FAB)
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/5531999999999
