# Template de secrets - copie para secrets.toml e preencha com os valores reais
# secrets.toml NAO deve ser commitado (esta no .gitignore)
# No Streamlit Cloud, cole o conteudo (com valores reais) na UI da app.

[origem]
user = "USUARIO_ORIGEM"
password = "SENHA_ORIGEM"
host = "host.do.crm"
port = "3306"
database = "schema_origem"

[destino]
user = "USUARIO_DESTINO"
password = "SENHA_DESTINO"
host = "host.do.dw"
port = "3310"
database = "dw_infratecnica"
